# add dis name to df
dis_als["DIS"] = "ALS"
dis_inx["DIS"] = "INX"
dis_key["DIS"] = "KEY"
dis_map["DIS"] = "MAP"
dis_mar["DIS"] = "MAR"
dis_mnt["DIS"] = "MNT"

print("checkpoint 3: added distributor name to df")

# stack dfs on top of each other
dis_stacked = pd.concat([dis_als, dis_inx, dis_key, dis_map, dis_mar, dis_mnt], axis=0, ignore_index=True)

print("checkpoint 4: stack complete")

# enter season
print("enter seasonand MF round, eg SS26_MF2:")
season = input(str())

# export dis_stacked as excel
timestamp = datetime.now().strftime("%Y-%m-%d_%H-%M")
output_file = f"C:/Users/luke.roberts/OneDrive - ASICS Corporation/Documents/vs_code/output/dis_consolidated_{season}_{timestamp}.xlsx"
dis_stacked.to_excel(output_file, index=False)

print(f"checkpoint 5: export to excel successful, saved as {output_file}")