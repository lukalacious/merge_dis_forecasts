# import libraries
import pandas as pd
from datetime import datetime

# import dis forecasts and specify sheet
dis_als = pd.read_excel("C:/Users/luke.roberts/OneDrive - ASICS Corporation/Documents/vs_code/data/SS26 FTW and APEQ MF1 Forecasting -- ALS.xlsx",
                        sheet_name="ASSORTMENT PLAN (FTW & APEQ)")
dis_key = pd.read_excel("C:/Users/luke.roberts/OneDrive - ASICS Corporation/Documents/vs_code/data/SS26 FTW and APEQ MF1 Forecasting -- KEY.xlsx",
                        sheet_name="ASSORTMENT PLAN (FTW & APEQ)")
dis_inx = pd.read_excel("C:/Users/luke.roberts/OneDrive - ASICS Corporation/Documents/vs_code/data/SS26 FTW and APEQ MF1 Forecasting -- INX.xlsx",
                        sheet_name="ASSORTMENT PLAN (FTW & APEQ)")
dis_map = pd.read_excel("C:/Users/luke.roberts/OneDrive - ASICS Corporation/Documents/vs_code/data/SS26 FTW and APEQ MF1 Forecasting -- MAP.xlsx",
                        sheet_name="ASSORTMENT PLAN (FTW & APEQ)")
dis_mar = pd.read_excel("C:/Users/luke.roberts/OneDrive - ASICS Corporation/Documents/vs_code/data/SS26 FTW and APEQ MF1 Forecasting -- MAR.xlsx",
                        sheet_name="ASSORTMENT PLAN (FTW & APEQ)")
dis_mnt = pd.read_excel("C:/Users/luke.roberts/OneDrive - ASICS Corporation/Documents/vs_code/data/SS26 FTW and APEQ MF1 Forecasting -- MNT.xlsx",
                        sheet_name="ASSORTMENT PLAN (FTW & APEQ)")

print("checkpoint 1: all excel files loaded")

# drop the top rows that are empty, 6 in this case
dis_als = dis_als.iloc[6:].reset_index(drop=True)
dis_inx = dis_inx.iloc[6:].reset_index(drop=True)
dis_key = dis_key.iloc[6:].reset_index(drop=True)
dis_map = dis_map.iloc[6:].reset_index(drop=True)
dis_mar = dis_mar.iloc[6:].reset_index(drop=True)
dis_mnt = dis_mnt.iloc[6:].reset_index(drop=True)

print("checkpoint 2: dropped empty rows and set first data row as column header")

# set the first row as column header
dis_als.columns = dis_als.iloc[0]
dis_als = dis_als[1:].reset_index(drop=True)

dis_inx.columns = dis_inx.iloc[0]
dis_inx = dis_inx[1:].reset_index(drop=True)

dis_key.columns = dis_key.iloc[0]
dis_key = dis_key[1:].reset_index(drop=True)

dis_mnt.columns = dis_mnt.iloc[0]
dis_mnt = dis_mnt[1:].reset_index(drop=True)

dis_map.columns = dis_map.iloc[0]
dis_map = dis_map[1:].reset_index(drop=True)

dis_mar.columns = dis_mar.iloc[0]
